# =============================================================
# MySQL MCP Server — Environment Configuration
# Copy this file to .env and fill in your values.
# Priority: CLI args > env vars > config file > defaults
# =============================================================

# -------------------------------------------------------------
# CONNECTION — choose ONE method
# -------------------------------------------------------------

# Option A: DSN string  (recommended for simple setups)
MYSQL_DSN=mysql://user:password@localhost:3306/database

# Option B: Individual connection variables
# Use this when your password contains special characters.
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=user
# MYSQL_PASSWORD=password
# MYSQL_DATABASE=database

# Option C: Multiple named connections (JSON object)
# Enables runtime switching via the use_connection tool.
# MYSQL_CONNECTIONS={"prod":{"dsn":"mysql://user:pass@prod-db:3306/app"},"staging":{"dsn":"mysql://user:pass@staging-db:3306/app"}}

# -------------------------------------------------------------
# QUERY LIMITS
# -------------------------------------------------------------

# Maximum rows returned by a single query (default: 200)
MYSQL_MAX_ROWS=200

# Query execution timeout in seconds (default: 30)
MYSQL_MCP_QUERY_TIMEOUT=30

# -------------------------------------------------------------
# FEATURE FLAGS
# -------------------------------------------------------------

# Enable all 25 tools, including 13 extended tools (default: false)
# Set to true to unlock: list_indexes, show_create_table, explain_query,
# list_views, list_triggers, list_procedures, list_functions,
# list_partitions, database_size, table_size, foreign_keys,
# list_status, list_variables
MYSQL_MCP_EXTENDED=false

# -------------------------------------------------------------
# HTTP TRANSPORT (for REST API / Postman testing)
# -------------------------------------------------------------

# Enable HTTP mode (default: false — uses stdio/MCP mode by default)
MYSQL_MCP_HTTP=false

# Port for the HTTP server (default: 3000)
MYSQL_MCP_HTTP_PORT=3000

# API key for HTTP endpoint authentication (default: disabled)
# When set, all requests must include: Authorization: Bearer <key>
# MYSQL_MCP_API_KEY=your-secret-api-key

# Enable per-IP rate limiting (default: false)
# MYSQL_MCP_RATE_LIMIT_ENABLED=false

# Sustained requests per second allowed per IP (default: 10)
# MYSQL_MCP_RATE_LIMIT_RPS=10

# Burst request capacity per IP (default: 20)
# MYSQL_MCP_RATE_LIMIT_BURST=20

# -------------------------------------------------------------
# LOGGING
# -------------------------------------------------------------

# Log level: debug | info | warn | error  (default: info)
# MYSQL_MCP_LOG_LEVEL=info

# Output logs as JSON (default: false)
# MYSQL_MCP_JSON_LOGS=false

# Suppress all log output — useful in stdio/MCP mode (default: false)
# MYSQL_MCP_SILENT=false

# Path to write a JSONL audit trail of all executed queries (default: disabled)
# MYSQL_MCP_AUDIT_LOG=./audit.jsonl

# -------------------------------------------------------------
# SSH TUNNEL (for databases behind a bastion host)
# -------------------------------------------------------------

# SSH bastion hostname or IP
# MYSQL_MCP_SSH_HOST=bastion.example.com

# SSH port (default: 22)
# MYSQL_MCP_SSH_PORT=22

# SSH username
# MYSQL_MCP_SSH_USER=ubuntu

# Path to SSH private key file
# MYSQL_MCP_SSH_KEY_PATH=~/.ssh/id_rsa
