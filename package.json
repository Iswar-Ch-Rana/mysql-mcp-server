{
  "name": "mysql-mcp-server",
  "version": "1.0.0",
  "description": "A read-only MySQL MCP server with multi-schema support",
  "type": "module",
  "bin": {
    "mysql-mcp-server": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js --transport http",
    "dev": "nodemon",
    "dev:http": "nodemon --exec \"tsx src/index.ts --transport http\"",
    "dev:stdio": "nodemon --exec \"tsx src/index.ts\"",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "gpt-tokenizer": "^2.8.0",
    "mysql2": "^3.12.0",
    "node-sql-parser": "^5.4.0",
    "ssh2": "^1.16.0",
    "winston": "^3.17.0",
    "yaml": "^2.6.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/nodemon": "^1.19.6",
    "@types/ssh2": "^1.15.0",
    "eslint": "^9.0.0",
    "nodemon": "^3.1.14",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
